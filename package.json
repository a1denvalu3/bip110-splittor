    "bitcoinjs-lib": "^7.0.1",
    "cors": "^2.8.6",
    "ecpair": "^3.0.1",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1",
    "tiny-secp256k1": "^2.2.4"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.1",
    "@types/sqlite3": "^3.1.11",
